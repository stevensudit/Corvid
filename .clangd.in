# clangd configuration. The repo-root `.clangd` is generated from `.clangd.in`
# by `tests/CMakeLists.txt` via `configure_file` and is gitignored (rewritten
# on every configure). Edit `.clangd.in`, not the generated `.clangd`, then
# re-run `./cleanbuild.sh` (or `cmake` directly) to regenerate.
CompileFlags:
  Compiler: /usr/bin/clang++-22
  # `compile_commands.json` lives under `tests/build/` (the only CMake project
  # in the repo). Without this, files outside `tests/`: e.g., the headers in
  # `corvid/proto/quic/`: fall back to default flags and clangd can't find
  # `<ngtcp2/ngtcp2.h>`, with the missing include cascading into spurious
  # "no matching constructor" / "unused private field" diagnostics.
  CompilationDatabase: tests/build

---
If:
  PathMatch: [.*\.cpp, .*\.cc, .*\.cxx, .*\.hpp, .*\.hh, .*\.hxx, .*\.h]
CompileFlags:
  Add: [-xc++, -std=c++23, -stdlib=libc++, -fexperimental-library, -D_LIBCPP_NO_ABI_TAG, -Wall, -Wextra, -Werror, -Wno-unused-variable]

---
If:
  PathMatch: .*\.c
CompileFlags:
  Compiler: /usr/bin/clang-22
  Add: [-xc, -std=c17]

---
# clangd's header-to-TU fallback sometimes picks a Catch2 source file as the
# parent TU for headers under `corvid/proto/`, which strips the `-isystem`
# paths for ngtcp2 and openssl and cascades into spurious "no matching
# constructor" / "unknown typename" diagnostics. Pin those paths here so the
# headers parse correctly regardless of which TU clangd inherits flags from.
# Note: PathMatch is matched against the path relative to this `.clangd` file
# (the project root), not the absolute path.
If:
  PathMatch: [corvid/proto/.*]
CompileFlags:
  Add: [-isystem, @NGTCP2_INCLUDE_DIR@, -isystem, @NGHTTP3_INCLUDE_DIR@, -isystem, @OPENSSL_INCLUDE_DIR@]

---
# CUDA sources/headers (corvid/cuda/, tests/*.cu). clangd otherwise parses
# these as plain C++ and flags the CUDA attributes (__host__, __device__,
# __global__) and the <<<...>>> launch syntax as unknown. Put clangd into CUDA
# mode with clang's own CUDA frontend (the one clangd embeds): -xcuda plus the
# toolkit path. clang-22 only "partially supports" up to CUDA 12.9, so
# --no-cuda-version-check silences the version-mismatch warning for the 13.3
# toolkit; parsing is unaffected.
#
# A .cu file (unlike a header) has an nvcc entry in compile_commands.json.
# clangd runs that command through its embedded clang, which rejects nvcc-only
# flags as "unknown argument", so strip them: -forward-unknown-to-host-compiler,
# -ccbin=..., and -arch=... (clang gets its arch via the default sm_52, which is
# fine for parsing).
If:
  PathMatch: [.*\.cu, .*\.cuh]
CompileFlags:
  Compiler: /usr/bin/clang++-22
  Remove: [-forward-unknown-to-host-compiler, -ccbin=*, -arch=*]
  Add: [-xcuda, --cuda-path=/usr/local/cuda, --no-cuda-version-check, -std=c++23]

---
Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None
