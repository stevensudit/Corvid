# GENERATED FILE -- DO NOT EDIT.
# This file is generated by `tests/CMakeLists.txt` from `.clangd.in` via
# `configure_file`. Edit `.clangd.in` instead and re-run `./cleanbuild.sh`
# (or `cmake` directly) to regenerate.
CompileFlags:
  Compiler: /usr/bin/clang++-22
  # `compile_commands.json` lives under `tests/build/` (the only CMake project
  # in the repo). Without this, files outside `tests/` -- e.g., the headers in
  # `corvid/proto/quic/` -- fall back to default flags and clangd can't find
  # `<ngtcp2/ngtcp2.h>`, with the missing include cascading into spurious
  # "no matching constructor" / "unused private field" diagnostics.
  CompilationDatabase: tests/build

---
If:
  PathMatch: [.*\.cpp, .*\.cc, .*\.cxx, .*\.hpp, .*\.hh, .*\.hxx, .*\.h]
CompileFlags:
  Add: [-xc++, -std=c++23, -stdlib=libc++, -D_LIBCPP_NO_ABI_TAG, -Wall, -Wextra, -Werror, -Wno-unused-variable]

---
If:
  PathMatch: .*\.c
CompileFlags:
  Compiler: /usr/bin/clang-22
  Add: [-xc, -std=c17]

---
# clangd's header-to-TU fallback sometimes picks a Catch2 source file as the
# parent TU for headers under `corvid/proto/`, which strips the `-isystem`
# paths for ngtcp2 and openssl and cascades into spurious "no matching
# constructor" / "unknown typename" diagnostics. Pin those paths here so the
# headers parse correctly regardless of which TU clangd inherits flags from.
# Note: PathMatch is matched against the path relative to this `.clangd` file
# (the project root), not the absolute path.
If:
  PathMatch: [corvid/proto/.*]
CompileFlags:
  Add: [-isystem, @NGTCP2_INCLUDE_DIR@, -isystem, @OPENSSL_INCLUDE_DIR@]

---
Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None
