{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/ide_build.sh",
            "args": [
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "absolute"
                ],
                "pattern": [
                    {
                        "regexp": "^(.*?):(\\d+):(\\d+):\\s+(?:fatal\\s+)?(warning|error):\\s+(.*)$",
                        "file": 1,
                        "line": 2,
                        "column": 3,
                        "severity": 4,
                        "message": 5
                    },
                    {
                        "regexp": "^\\s+(?!\\d+\\s+|\\s+\\|)(.*)$",
                        "message": 1,
                        "loop": true
                    }
                ]
            },
            "detail": "Build the current .cpp (clang++/libc++) or .cu (nvcc/g++-15) file to debug_bin/."
        },
        {
            "label": "Run Executable",
            "type": "shell",
            "command": "${fileDirname}/debug_bin/${fileBasenameNoExtension}",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
